{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (TAC_WebAPI)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/TA-WebApi/src/TAC_WebAPI/bin/Debug/net8.0/TAC_WebAPI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/TA-WebApi/src/TAC_WebAPI",
      "stopAtEntry": false,
      "internalConsoleOptions": "openOnSessionStart",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_CLI_HOME": "${workspaceFolder}/.dotnet-home"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/TA-WebApi/src/TAC_WebAPI/Views"
      }
    },
    {
      "name": ".NET Core Launch (UI Layer - Lab)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-lab",
      "program": "${workspaceFolder}/src/UI/bin/Debug/net10.0/UI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/UI",
      "stopAtEntry": false,
      "internalConsoleOptions": "openOnSessionStart",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_CLI_HOME": "${workspaceFolder}/.dotnet-home"
      }
    }
  ]
}