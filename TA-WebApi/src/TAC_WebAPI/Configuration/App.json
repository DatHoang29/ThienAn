{
  "Urls": "http://*:5005", // Port
  // "https_port": 44325,
  "AllowedHosts": "*",
  "AppSettings": {
    "InjectSpecificationDocument": true, // Enable Swagger
    "ExternalAssemblies": [ "plugins" ] // Modular folder
  },
  "DynamicApiControllerSettings": {
    //"DefaultRoutePrefix": "api", // Default route prefix
    "CamelCaseSeparator": "", // Camel case separator
    "SplitCamelCase": false, // Split camel case / Pascal case
    "LowercaseRoute": false, // Lowercase route format
    "AsLowerCamelCase": true, // Lower camel case (first letter lowercase)
    "KeepVerb": false, // Preserve action method request verbs
    "KeepName": false // Preserve original names without modification
  },
  "FriendlyExceptionSettings": {
    "DefaultErrorMessage": "System exception, please contact the administrator",
    "ThrowBah": true, // Whether to throw Oops.Oh as a business exception by default
    "LogError": false // Whether to log exceptions
  },
  "LocalizationSettings": {
    "SupportedCultures": [ "vi-VN", "en" ], // List of languages
    "DefaultCulture": "vi-VN", // Default language
    "DateTimeFormatCulture": "vi-VN" // Fixed time zone for specific culture (multilingual)
  },
  "CorsAccessorSettings": {
    //"PolicyName": "App.Cors.Policy",
    //"WithOrigins": [ "http://localhost:5005", "" ],
    "WithExposedHeaders": [ "Content-Disposition", "X-Pagination", "access-token", "x-access-token" ], // If the front end is not a proxy and it is an axios request
    "SignalRSupport": true // SignalR support
  }
}